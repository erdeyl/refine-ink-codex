{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python scripts/*)",
      "Bash(python scripts/*)",
      "Bash(pip install*)",
      "Bash(.venv/bin/pip install*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(ln*)",
      "Bash(ls*)",
      "Bash(source .venv/bin/activate*)",
      "Read",
      "Write(reviews/**)",
      "Write(output/**)",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Task"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push*)",
      "Write(reviews/*/input/*)",
      "Edit(reviews/*/input/*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ CONTEXT COMPACTION IMMINENT — Save critical state to reviews/*/agent_outputs/context_state.md before compaction. Include: current phase, completed agents, pending agents, key findings so far, and next steps.'"
          }
        ]
      }
    ]
  }
}
